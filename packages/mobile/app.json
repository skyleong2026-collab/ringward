{
  "expo": {
    "name": "8gents",
    "slug": "8gents-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "8gents",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTabletScale": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find creatures nearby",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to find creatures nearby",
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ]
      },
      "bundleIdentifier": "com.anonymous.x8gentsmobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080810",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.x8gentsmobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080810",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ]
  }
}
